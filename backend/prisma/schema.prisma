generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums --------------------------------------------------------------------

enum Role {
  ADMIN
}

enum Priority {
  HIGH
  NORMAL
}

enum BookingStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum EventType {
  SLOT_DETECTED
  BOOKING_ATTEMPT
  BOOKING_SUCCESS
  BOOKING_FAILED
  IP_BLOCKED
  SESSION_EXPIRED
  CAPTCHA_REQUIRED
  CAPTCHA_SOLVED
  MONITOR_STARTED
  MONITOR_STOPPED
}

enum ProxyStatus {
  ACTIVE
  BLOCKED
  DISABLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// --- Models -------------------------------------------------------------------

model GlobalSettings {
  id            String   @id @default("singleton")
  proxyHost     String?
  proxyPort     Int?
  proxyUsername String?
  proxyPassword String?
  updatedAt     DateTime @updatedAt
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  role              Role               @default(ADMIN)
  refreshTokenHash  String?
  pushSubscriptions PushSubscription[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("users")
}

model Profile {
  id                String    @id @default(cuid())
  statusToken       String    @unique
  fullName          String
  passportNumberEnc String // AES-256-GCM encrypted
  dobEnc            String // AES-256-GCM encrypted
  passportExpiry    DateTime
  nationality       String
  email             String
  phone             String
  gender            Gender    @default(MALE)
  passportIssueDate DateTime?
  vfsPasswordEnc    String? // AES-256-GCM encrypted VFS portal login password
  passportImageEnc  String? // AES-256-GCM encrypted base64 of passport BIO-page scan
  telegramChatId    String? // Per-customer Telegram chat ID for booking alerts
  priority          Priority  @default(NORMAL)
  isActive          Boolean   @default(true)
  bookings          Booking[]
  logs              Log[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("profiles")
}

model Booking {
  id             String        @id @default(cuid())
  profile        Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId      String
  destination    String // "brazil" | "portugal"
  visaType       String
  slotDate       DateTime?
  slotTime       String?
  status         BookingStatus @default(QUEUED)
  confirmationNo String?
  proxyUsed      String?
  attempt        Int           @default(1)
  errorMessage   String?
  jobId          String? // BullMQ job ID
  createdAt      DateTime      @default(now())
  completedAt    DateTime?

  @@index([profileId])
  @@index([status])
  @@index([createdAt])
  @@map("bookings")
}

model Log {
  id          String    @id @default(cuid())
  timestamp   DateTime  @default(now())
  level       LogLevel
  eventType   EventType
  message     String
  profile     Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  profileId   String?
  destination String?
  result      String?
  proxyUsed   String?
  metadata    Json?

  @@index([timestamp])
  @@index([profileId])
  @@index([eventType])
  @@map("logs")
}

model Settings {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Proxy {
  id            String      @id @default(cuid())
  host          String
  port          Int
  username      String
  passwordEnc   String // AES-256-GCM encrypted
  provider      String
  country       String      @default("AO")
  status        ProxyStatus @default(ACTIVE)
  blockCount    Int         @default(0)
  lastUsedAt    DateTime?
  lastBlockedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("proxies")
}

model PushSubscription {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

enum AccountStatus {
  PENDING
  ACTIVE
  BLOCKED
  COOLDOWN
}

enum PollingRole {
  WATCHER
  BOOKER
  BOTH
}

enum LifecycleStateEnum {
  NEW
  REGISTERING
  REGISTER_FAILED
  PENDING_ACTIVATION
  ACTIVATING
  ACTIVE
  LOGGING_IN
  WARM
  RESTRICTED
  BLOCKED
  BOOKED
}

model VfsAccount {
  id                String        @id @default(uuid())
  email             String        @unique
  encryptedPassword String
  phone             String?
  smsExternalId     String?
  status            AccountStatus @default(ACTIVE)
  pollingRole       PollingRole   @default(BOTH)
  lastUsedAt        DateTime?
  cooldownUntil     DateTime?
  cookieStore       Json?
  lastWarmedAt      DateTime?
  lifecycleState    LifecycleStateEnum @default(NEW)
  attemptCount      Int                @default(0)
  lastAttemptAt     DateTime?
  restrictedReason  String?
  lastError         String?
  tabUrl            String?
  profileIds        String[]
  bookingConfirmation String?
  bookedAt          DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model ReceivedEmail {
  id          String   @id @default(cuid())
  toAddress   String
  fromAddress String?
  subject     String?
  body        String   @db.Text
  rawHeaders  Json?
  receivedAt  DateTime @default(now())

  @@index([toAddress])
  @@map("received_emails")
}

enum VendorKind {
  SMS
  EMAIL
  CAPTCHA
  PROXY
  OTHER
}

enum PipelineSeverity {
  INFO
  WARN
  CRITICAL
}

// Every billable action against a paid third-party (vendor) is logged here.
// Cost stored as integer micro-USD so we never lose cents to float math.
model VendorSpend {
  id           String     @id @default(cuid())
  vendor       String // 'onlinesim' | 'vaksms' | '2captcha' | 'kopeechka' | 'mailsac' | 'brightdata'
  kind         VendorKind
  action       String // 'buy_number' | 'get_otp' | 'solve_turnstile' | 'fetch_inbox' | etc.
  costMicroUsd Int // 1_000_000 = $1.00 ; integer to avoid float drift
  externalRef  String? // vendor-side id (tzid, captchaId, mailboxId)
  profileId    String? // who this spend was for (null = pool / overhead)
  meta         Json? // service tag, country, sender id, anything diagnostic
  createdAt    DateTime   @default(now())

  @@index([vendor])
  @@index([profileId])
  @@index([createdAt])
  @@map("vendor_spend")
}

model PipelineEvent {
  id             String            @id @default(cuid())
  action         String            // e.g. "register", "activate", "login", "book", "slot_check"
  accountId      String?
  profileId      String?
  beforeState    String?           // lifecycle state before action
  afterState     String?           // lifecycle state after action
  error          String?           // error message if failed
  url            String?           // VFS URL at time of event
  screenshotPath String?           // path to screenshot file
  lastNetwork    String?           // last network call observed (JSON stringified)
  severity       PipelineSeverity  @default(INFO)
  createdAt      DateTime          @default(now())

  @@index([accountId])
  @@index([profileId])
  @@index([severity])
  @@index([createdAt])
  @@map("pipeline_events")
}
