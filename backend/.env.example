# ─── Backend environment (canonical schema: src/config/env.ts) ───────────────
# Copy to .env and fill in. Secrets must never be committed.

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Datastores (required) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/vfs
REDIS_URL=redis://localhost:6379

# ── Auth / crypto (required) ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=                 # >= 32 chars
JWT_REFRESH_SECRET=                # >= 32 chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PROFILE_ENCRYPTION_KEY=            # exactly 64 hex chars (32 bytes) for AES-256

# ── Captcha ──────────────────────────────────────────────────────────────────
CAPTCHA_SOLVER=manual              # twocaptcha | manual
TWOCAPTCHA_API_KEY=
CAPMONSTER_KEY=

# ── SMS (account registration OTP) ───────────────────────────────────────────
SMS_PROVIDER=smsactivate           # smsactivate | vaksms | onlinesim
SMS_ACTIVATE_API_KEY=
ONLINESIM_API_KEY=
VAKSMS_API_KEY=
VAKSMS_COUNTRY=uz

# ── Automation gates (all OFF by default — enable deliberately) ───────────────
# Orchestrator auto-pilot. false = plan-only (never touches VFS).
ORCHESTRATOR_ENABLED=false
# 6-hourly mass-login refresh cron. OFF — it logs in every stale account at once
# and is a prime trigger for VFS 429001 "Access Restricted". Enable only with
# per-account throttling / fresh-IP rotation in place.
LOGIN_CRON_ENABLED=false
# Telegram/email BOOKING_FAILED alerts. OFF so dev test fires / EXT_SESSION_LOST
# don't spam the operator/client channel (failures still logged). Turn on in prod.
NOTIFY_BOOKING_FAILURES=false

# ── Proxy (UZ residential — BrightData) ──────────────────────────────────────
PROXY_DEFAULT_PROVIDER=brightdata
PROXY_HOST=brd.superproxy.io
PROXY_PORT=33335
PROXY_USERNAME=                    # brd-customer-...-zone-residential...-country-uz
PROXY_PASSWORD=
CDP_ENDPOINT=
BRIGHTDATA_WS=
SCRAPER_API=
SCRAPER_API_PREMIUM=true
SCRAPER_API_COUNTRY=uz
SCRAPER_API_MAX_REQUESTS_PER_HOUR=200

# ── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VFS Bot" <noreply@example.com>
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── VFS test account ─────────────────────────────────────────────────────────
VFS_EMAIL=
VFS_PASSWORD=

# ── Disposable email (account registration) ──────────────────────────────────
EMAIL_PROVIDER=mailsac             # mailsac | custom
MAILSAC_API_KEY=
EMAIL_DOMAIN=
CUSTOM_EMAIL_DOMAIN=
EMAIL_WEBHOOK_SECRET=

# ── Booking / monitor tuning ─────────────────────────────────────────────────
BOOKING_CONCURRENCY=3
BOOKING_DRY_RUN=true               # false = real submit
MONITOR_DEFAULT_INTERVAL_MS=5000
MONITOR_MIN_INTERVAL_MS=5000
CAPTCHA_TOKEN_POOL_SIZE=3
CAPTCHA_TOKEN_MAX_AGE_MS=90000
SESSION_DIR=/app/sessions
BOOKING_MAX_RETRIES=3
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
