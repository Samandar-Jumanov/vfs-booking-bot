# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vfsuser:vfspass@localhost:5432/vfsdb

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispass@localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex string — generate with: openssl rand -hex 32
PROFILE_ENCRYPTION_KEY=

# ─── Captcha ──────────────────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=
# Options: twocaptcha | manual
CAPTCHA_SOLVER=twocaptcha

# SMS Provider: 'smsactivate' (default) or 'vaksms'
SMS_PROVIDER=vaksms
VAKSMS_API_KEY=
VAKSMS_COUNTRY=uz

# Email Provider: 'mailsac' (default) or 'custom' (your own domain + webhook)
EMAIL_PROVIDER=custom
CUSTOM_EMAIL_DOMAIN=yourbookingco.com
EMAIL_WEBHOOK_SECRET=  # set this and require X-Webhook-Secret header

# ─── Proxy ────────────────────────────────────────────────────────────────────
# Default provider label shown in UI
PROXY_DEFAULT_PROVIDER=proxyrack
PROXY_HOST=premium.residential.proxyrack.net
PROXY_PORT=10000
PROXY_USERNAME=
PROXY_PASSWORD=
BRIGHTDATA_WS=

# ScraperAPI fallback (alternative to BrightData)
# Get from https://scraperapi.com - Hobby plan or higher required for protected targets
SCRAPER_API=
SCRAPER_API_PREMIUM=true       # set false to use datacenter pool (cheaper, weaker)
SCRAPER_API_COUNTRY=uz         # exit country
SCRAPER_API_MAX_REQUESTS_PER_HOUR=200

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PROXY=

# ─── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="VFS Bot <noreply@example.com>"

# ─── Web Push ─────────────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ─── Automation ───────────────────────────────────────────────────────────────
# Number of concurrent Playwright booking jobs (each ~200MB RAM)
BOOKING_CONCURRENCY=3
# When true (default), booking runs the full flow but stops at the review screen and screenshots it. Set to 'false' only for live submission.
BOOKING_DRY_RUN=true
# Default monitor poll interval in milliseconds
MONITOR_DEFAULT_INTERVAL_MS=10000
# Directory for per-profile session cookies
SESSION_DIR=/app/sessions
# Max booking retry attempts per job
BOOKING_MAX_RETRIES=3
