# Exclude workspace symlinks that Docker's tar archiver cannot handle
node_modules
**/node_modules

# Build artifacts
backend/dist
frontend/.next
**/dist
**/.next
*.tsbuildinfo

# Secrets / env (any .env file)
**/.env
**/.env.*
!**/.env.example
!**/.env.production.example

# Logs
*.log
**/logs

# VCS / IDE / agent metadata
.git
.gitignore
.claude
.claude-flow
.codex
.cursor
.vscode
.idea

# Test artifacts
playwright-report
test-results
coverage
