# ──────────────────────────────────────────────────────────────────────────
# Production environment variables for the VFS booking bot.
# Copy to .env.production, fill in real values, NEVER commit to git.
#
# Generate secrets:
#   openssl rand -hex 64   # for JWT_*
#   openssl rand -hex 32   # for PROFILE_ENCRYPTION_KEY
#   openssl rand -hex 32   # for EMAIL_WEBHOOK_SECRET
# ──────────────────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Comma-separated list of allowed origins (Vercel + custom dashboard).
FRONTEND_URL=https://app.yourbookingbot.com

# ── Database (Neon/Supabase or in-compose Postgres) ───────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST:5432/vfsdb?schema=public&sslmode=require
# Used only by docker-compose.prod.yml — ignore if using Neon/Supabase.
POSTGRES_USER=vfsuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=vfsdb

# ── Redis (Upstash or in-compose Redis) ───────────────────────────────────
REDIS_URL=redis://default:PASS@HOST:6379
REDIS_PASSWORD=CHANGE_ME

# ── Auth / Crypto ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_TO_64_HEX_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_TO_64_HEX_CHARS_DIFFERENT
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PROFILE_ENCRYPTION_KEY=CHANGE_ME_TO_64_HEX_CHARS_32_BYTES

# ── Captcha ───────────────────────────────────────────────────────────────
TWOCAPTCHA_API_KEY=YOUR_2CAPTCHA_KEY
CAPTCHA_SOLVER=twocaptcha

# ── SMS Provider (choose one) ─────────────────────────────────────────────
SMS_PROVIDER=vaksms
VAKSMS_API_KEY=YOUR_VAK_SMS_KEY
VAKSMS_COUNTRY=uz
# Fallback to sms-activate if desired:
# SMS_ACTIVATE_API_KEY=

# ── Email Provider (choose one) ───────────────────────────────────────────
# 'custom' = use /api/email/webhook + your own domain (RECOMMENDED for VFS)
# 'mailsac' = use mailsac.com (free *@mailsac.com may be flagged by VFS)
EMAIL_PROVIDER=custom
CUSTOM_EMAIL_DOMAIN=yourbookingbot.com
EMAIL_WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM_STRING
MAILSAC_API_KEY=

# ── Booking Pipeline ──────────────────────────────────────────────────────
# Route bookings through the operator's extension (account-pool model).
EXTENSION_BOOKING=true
# Operator's user.id from prisma. The auto-register service + booking dispatch
# send WS messages to this user. If unset, falls back to the first ADMIN.
OPERATOR_USER_ID=
BOOKING_CONCURRENCY=3
BOOKING_MAX_RETRIES=3
MONITOR_DEFAULT_INTERVAL_MS=30000
# Set to "false" to skip auto-spawning DB-stored monitors at boot (useful during deploys).
MONITOR_AUTO_START=true
SESSION_DIR=/app/sessions

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
# Operator's personal chat ID (gets every alert).
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# ── Optional: VFS test account (only used when there's exactly 1 account in pool) ──
VFS_EMAIL=
VFS_PASSWORD=

# ── Optional: Datadome research vars (unused in extension architecture) ──
# CDP_ENDPOINT=
# BRIGHTDATA_WS=
# SCRAPER_API=
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USERNAME=
# PROXY_PASSWORD=
